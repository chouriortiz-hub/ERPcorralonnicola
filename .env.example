# Copiá este archivo a ".env" en local si querés probar con estas variables,
# o cargalas directamente en el panel de Railway/Render en producción.
# NUNCA subas un archivo ".env" real (con valores reales) a GitHub.

DJANGO_SECRET_KEY=cambiar-por-una-clave-larga-y-aleatoria
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=tuerp.up.railway.app

# La arma automáticamente Railway/Render al crear la base Postgres del proyecto
DATABASE_URL=postgres://usuario:password@host:5432/nombre_db

# ARCA (ex-AFIP) - completar solo cuando tengas el certificado
ARCA_CUIT=
ARCA_CERT_PATH=
ARCA_KEY_PATH=
ARCA_PRODUCCION=False
